# ============================================================
# ScholarMind 环境变量配置
# 
# 使用方法:
# 1. 复制本文件为 .env:  copy .env.example .env
# 2. 填入你的真实 API Key
# 3. 确认 .env 已被 .gitignore 排除 (绝不提交!)
# ============================================================

# [必需] MiniMax API Key
# 获取方式: https://platform.minimaxi.com/
MINIMAX_API_KEY=你的key

# [可选] MiniMax API 基础 URL
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# [可选] MiniMax 模型名称
# 文本模型: MiniMax-Text-01
# 多模态模型: MiniMax-M2 (支持 Vision 图表分析)
MINIMAX_MODEL=MiniMax-Text-01

# [推荐] Semantic Scholar API Key (提高论文搜索请求限额)
# 获取方式: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=你的key

# [可选] 成本控制
MAX_TOKENS_PER_SESSION=50000
