# ============================================================
# ScholarMind 环境变量配置
# 
# 使用方法:
# 1. 复制本文件为 .env:  copy .env.example .env
# 2. 填入你的真实 API Key
# 3. 确认 .env 已被 .gitignore 排除 (绝不提交!)
# ============================================================

# [必需] Anthropic API Key (Claude API)
# 获取方式: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-你的key

# [推荐] Semantic Scholar API Key (提高论文搜索请求限额)
# 获取方式: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=你的key

# [可选] 模型选择 (默认 claude-sonnet-4-20250514)
# 可选: claude-sonnet-4-20250514, claude-opus-4-20250514
DEFAULT_MODEL=claude-sonnet-4-20250514

# [可选] 成本控制
MAX_TOKENS_PER_SESSION=50000
MAX_COST_PER_SESSION_USD=0.50
